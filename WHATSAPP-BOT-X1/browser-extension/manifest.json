{
  "manifest_version": 3,
  "name": "Copiloto WhatsApp",
  "version": "1.0.0",
  "description": "Captura dados da conversa aberta no WhatsApp Web e envia para o painel Copiloto local.",
  "permissions": ["tabs", "storage"],
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "http://127.0.0.1:8787/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Copiloto WhatsApp"
  }
}
